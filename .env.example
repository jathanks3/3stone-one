# Copy to .env.local for local development. Never commit the real file —
# .env, .env.local, and every other .env* variant are gitignored; this
# file holds placeholder names only, no real values.
#
# See docs/16-database-operations.md for where these come from (Neon +
# Vercel) and how to rotate them.

# Pooled Neon connection — used by the running app (src/server/db.ts).
# Set automatically by Vercel's Neon marketplace integration in every
# connected environment; only needed here for local development.
DATABASE_URL="postgresql://user:password@host-pooler.region.aws.neon.tech/dbname?sslmode=require"

# Direct (unpooled) Neon connection — used only by the Prisma CLI
# (migrate, db pull, studio), via prisma.config.ts. Migrations need
# session-level features a pgbouncer pooled connection doesn't support.
# Vercel's Neon integration names this DATABASE_URL_UNPOOLED, not
# DIRECT_URL — prisma.config.ts checks DIRECT_URL first, then falls back
# to DATABASE_URL_UNPOOLED, so either name works.
DATABASE_URL_UNPOOLED="postgresql://user:password@host.region.aws.neon.tech/dbname?sslmode=require"

# Founder's own login — read by prisma/seed.ts to grant the initial
# StaffMembership(role: "founder"). Never hardcode a real email into a
# committed file.
FOUNDER_EMAIL="you@3stoneai.com"
