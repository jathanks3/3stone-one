// =============================================================================
// PLATFORM ("3Stone AI" internal operations) — docs/15-company-platform-vision.md
//
// Every model below is prefixed platform_ at the table-name level (@@map) so
// the boundary between "workspace product data" and "internal operator data"
// is mechanical and greppable — the seam that would let this be extracted
// into its own service later without touching the tables above.
//
// None of this is visible to a customer under any circumstance — enforced in
// application code by a four-layer gate (middleware, section layout, API,
// nav), not by anything in this schema, but the *data* boundary starts here.
// =============================================================================

enum StaffRole {
  founder
  operations
  support
}

enum StaffMembershipStatus {
  active
  revoked
}

model StaffMembership {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id])
  role            StaffRole
  status          StaffMembershipStatus @default(active)
  grantedAt       DateTime @default(now())
  grantedByUserId String?
  revokedAt       DateTime?

  @@map("platform_staff_memberships")
}

enum SubscriptionStatus {
  trialing
  active
  past_due
  canceled
  paused
}

model Subscription {
  id                   String   @id @default(cuid())
  workspaceId          String   @unique
  workspace            Workspace @relation(fields: [workspaceId], references: [id])
  stripeCustomerId     String?
  stripeSubscriptionId String?
  stripePriceId        String?
  cancelAtPeriodEnd    Boolean  @default(false)
  plan                 WorkspacePlan @default(free)
  status               SubscriptionStatus @default(trialing)
  isFounderPricing     Boolean  @default(false)
  priceOverrideCents   Int?
  mrrCents             Int      @default(0)
  trialEndsAt          DateTime?
  currentPeriodEnd     DateTime?
  createdAt            DateTime @default(now())

  @@map("platform_subscriptions")
}

// 3Stone AI -> workspace billing — distinct from the workspace's own Invoice
// (which is that customer's AR to *their* clients).
enum PlatformInvoiceStatus {
  draft
  open
  paid
  void
  uncollectible
}

model PlatformInvoice {
  id              String   @id @default(cuid())
  workspaceId     String
  workspace       Workspace @relation(fields: [workspaceId], references: [id])
  stripeInvoiceId String?  @unique
  amountCents     Int
  status          PlatformInvoiceStatus @default(draft)
  dueDate         DateTime?
  paidAt          DateTime?
  createdAt       DateTime @default(now())

  @@map("platform_invoices")
}

enum SupportTicketStatus {
  open
  pending
  resolved
  closed
}

enum SupportTicketPriority {
  low
  normal
  high
  urgent
}

model SupportTicket {
  id                String   @id @default(cuid())
  workspaceId       String
  workspace         Workspace @relation(fields: [workspaceId], references: [id])
  requestedByEmail  String
  subject           String
  status            SupportTicketStatus @default(open)
  priority          SupportTicketPriority @default(normal)
  assignedStaffId   String?
  createdAt         DateTime @default(now())
  resolvedAt        DateTime?

  messages          SupportTicketMessage[]

  @@map("platform_support_tickets")
}

enum SupportAuthorType {
  staff
  customer
}

model SupportTicketMessage {
  id         String   @id @default(cuid())
  ticketId   String
  ticket     SupportTicket @relation(fields: [ticketId], references: [id])
  authorType SupportAuthorType
  authorId   String?
  body       String
  createdAt  DateTime @default(now())

  @@map("platform_support_ticket_messages")
}

model FeatureFlag {
  key            String   @id
  label          String
  description    String?
  defaultEnabled Boolean  @default(false)
  createdAt      DateTime @default(now())

  overrides      WorkspaceFeatureOverride[]

  @@map("platform_feature_flags")
}

model WorkspaceFeatureOverride {
  id          String   @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  flagKey     String
  flag        FeatureFlag @relation(fields: [flagKey], references: [key])
  enabled     Boolean

  @@unique([workspaceId, flagKey])
  @@map("platform_workspace_feature_overrides")
}

enum AnnouncementAudience {
  all
  plan_tier
  specific_workspaces
}

model PlatformAnnouncement {
  id          String   @id @default(cuid())
  title       String
  body        String
  audience    AnnouncementAudience @default(all)
  publishedAt DateTime?
  createdAt   DateTime @default(now())

  targets     PlatformAnnouncementTarget[]

  @@map("platform_announcements")
}

// Join table — which specific workspaces an audience:"specific_workspaces"
// announcement targets, and (once read-tracking exists) who's seen it.
model PlatformAnnouncementTarget {
  id             String   @id @default(cuid())
  announcementId String
  announcement   PlatformAnnouncement @relation(fields: [announcementId], references: [id])
  workspaceId    String
  workspace      Workspace @relation(fields: [workspaceId], references: [id])
  viewedAt       DateTime?

  @@unique([announcementId, workspaceId])
  @@map("platform_announcement_targets")
}

// Every staff action, cross-tenant. This is the audit trail for "who looked
// at what, who changed what" — including Open Workspace entries, which must
// always write a row here (docs/15: "every entry is audited").
model PlatformAuditLogEntry {
  id                String   @id @default(cuid())
  staffUserId       String
  action            String
  targetWorkspaceId String?
  targetEntityType  String?
  targetEntityId    String?
  metadata          Json?
  createdAt         DateTime @default(now())

  @@index([targetWorkspaceId, createdAt])
  @@index([staffUserId, createdAt])
  @@map("platform_audit_log_entries")
}

model AiUsageLog {
  id           String   @id @default(cuid())
  workspaceId  String
  workspace    Workspace @relation(fields: [workspaceId], references: [id])
  date         DateTime @db.Date
  aiCallCount  Int      @default(0)
  tokensUsed   Int      @default(0)
  costCents    Int      @default(0)

  @@unique([workspaceId, date])
  @@map("platform_ai_usage_logs")
}

model StorageUsageSnapshot {
  id          String   @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  bytesUsed   BigInt
  snapshotAt  DateTime @default(now())

  @@index([workspaceId, snapshotAt])
  @@map("platform_storage_usage_snapshots")
}

// Real per-file metadata for every upload — the file bytes themselves
// live in Supabase Storage (storage only; see docs/18-architecture-inventory.md
// for why Supabase Auth/Postgres are NOT used here), this is the Neon-side
// record that makes tenant isolation, permissions, and audit logging
// possible without touching Supabase's own auth system at all: every
// signed upload/download URL is only ever issued after a check against
// this table's workspaceId, using this app's own session/permission
// checks, never Supabase RLS.
enum UploadedFileKind {
  avatar
  logo
  document
}

model UploadedFile {
  id               String   @id @default(cuid())
  workspaceId      String
  workspace        Workspace @relation(fields: [workspaceId], references: [id])
  uploadedByUserId String
  uploadedBy       User     @relation(fields: [uploadedByUserId], references: [id])
  kind             UploadedFileKind
  storagePath      String   @unique
  originalFilename String
  mimeType         String
  sizeBytes        Int
  createdAt        DateTime @default(now())

  @@index([workspaceId, kind])
  @@map("uploaded_files")
}

enum LegalDocumentType {
  tos
  privacy
  saas_agreement
  dpa
}

model LegalAcceptance {
  id              String   @id @default(cuid())
  workspaceId     String?
  workspace       Workspace? @relation(fields: [workspaceId], references: [id])
  userId          String?
  personId        String?
  person          Person?  @relation(fields: [personId], references: [id])
  documentType    LegalDocumentType
  documentVersion String
  acceptedAt      DateTime @default(now())
  ipAddress       String?

  @@map("platform_legal_acceptances")
}

// Customer Onboarding — every step persisted individually, not a single
// "current step" pointer, so Customer 360's progress bar is a real
// count of completed rows, never a fabricated percentage (docs/15 /
// the founder's onboarding charter). The first three steps
// (account_created, email_verified, password_created) happen before a
// Workspace exists at all — they're derived from User fields
// (User row existing, emailVerifiedAt, passwordHash) rather than rows
// here; everything from workspace_created onward gets a real row the
// moment it's actually completed.
model OnboardingStepDefinition {
  key       String   @id
  label     String
  sortOrder Int
  progress  WorkspaceOnboardingProgress[]

  @@map("platform_onboarding_step_definitions")
}

model WorkspaceOnboardingProgress {
  id          String   @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  stepKey     String
  step        OnboardingStepDefinition @relation(fields: [stepKey], references: [key])
  completedAt DateTime @default(now())

  @@unique([workspaceId, stepKey])
  @@map("platform_workspace_onboarding_progress")
}

// 3Stone AI's OWN sales pipeline — people considering becoming a
// customer, not customers yet. Deliberately a separate model from CRM's
// Person/Deal (a customer's own leads, tenant-scoped, a completely
// different concept) and separate from CustomerLifecycleStage (which
// starts only once someone IS a customer). A prospect leaves this
// pipeline the moment they convert — see convertedWorkspaceId.
enum SalesPipelineStage {
  lead
  discovery_scheduled
  proposal_draft
  proposal_sent
  negotiation
  won
  lost
}

model SalesProspect {
  id                 String   @id @default(cuid())
  name               String
  email              String
  businessName        String?
  stage              SalesPipelineStage @default(lead)
  convertedWorkspaceId String?
  convertedWorkspace  Workspace? @relation(fields: [convertedWorkspaceId], references: [id])
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@map("platform_sales_prospects")
}

enum EmailDeliveryStatus {
  sent
  delivered
  bounced
  failed
}

model EmailDeliveryLog {
  id          String   @id @default(cuid())
  toAddress   String
  template    String
  provider    String
  status      EmailDeliveryStatus
  workspaceId String?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id])
  sentAt      DateTime @default(now())

  @@map("platform_email_delivery_logs")
}
