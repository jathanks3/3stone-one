// 3Stone One — Prisma schema
//
// This is the real target schema described in docs/03-database-schema.md,
// extended per docs/15-company-platform-vision.md with:
//   - Product / Edition modeling (foundational, not a future migration —
//     every Workspace defaults to Product "3stone_one" / Edition "business")
//   - Customer Lifecycle as a data-driven lookup table (CustomerLifecycleStage),
//     not a hardcoded enum — same reasoning docs/13-self-critique.md #1 already
//     applied to industry pipeline stages: extensible without a migration.
//   - The "3Stone AI" internal operations tables (platform_* — see the
//     PLATFORM section below), for founder/staff use only, never customer-visible.
//
// Multi-tenancy: every workspace-scoped model carries workspaceId and is
// scoped to it at the service layer (see docs/01-architecture.md §3).

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

// Connection URLs live in prisma.config.ts (Prisma 7 moved them out of the
// schema file entirely) — url (pooled, DATABASE_URL) for the app and
// Prisma Client, directUrl (unpooled, DIRECT_URL) for schema-changing
// commands (migrate dev/deploy, db push), which need session-level
// features a pgbouncer pooled connection doesn't support.
datasource db {
  provider = "postgresql"
}

// =============================================================================
// PRODUCT / EDITION — foundational (docs/15): 3Stone AI is a multi-product
// company. Every Workspace belongs to exactly one Product and one Edition of
// that product. Today only 3stone_one/business is real; Bet AI and future
// editions are rows, not code branches, so adding one is data, not a migration.
// =============================================================================

model Product {
  key       String    @id
  name      String
  createdAt DateTime  @default(now())
  editions  Edition[]
  workspaces Workspace[]

  @@map("products")
}

model Edition {
  key        String    @id
  productKey String
  product    Product   @relation(fields: [productKey], references: [key])
  name       String
  createdAt  DateTime  @default(now())
  workspaces Workspace[]

  @@unique([productKey, key])
  @@map("editions")
}

// =============================================================================
// CUSTOMER LIFECYCLE — foundational (docs/15): data-driven, not an enum, so
// adding a stage later is a seed insert, never a schema migration.
// Seeded stages: lead, demo_scheduled, trial, active, power_user, at_risk,
// cancelled, former_customer.
// =============================================================================

model CustomerLifecycleStage {
  key        String      @id
  label      String
  sortOrder  Int
  isTerminal Boolean     @default(false)
  workspaces Workspace[]

  @@map("customer_lifecycle_stages")
}

// =============================================================================
// TENANCY & IDENTITY
// =============================================================================

model Workspace {
  id                 String    @id @default(cuid())
  name               String
  slug               String    @unique
  industryProfileKey String?
  industryProfile    IndustryProfile? @relation(fields: [industryProfileKey], references: [key])
  productKey         String    @default("3stone_one")
  product            Product   @relation(fields: [productKey], references: [key])
  editionKey         String    @default("business")
  edition            Edition   @relation(fields: [editionKey], references: [key])
  lifecycleStageKey  String    @default("lead")
  lifecycleStage     CustomerLifecycleStage @relation(fields: [lifecycleStageKey], references: [key])
  logoUrl            String?
  timezone           String?
  address            String?
  contactEmail       String?
  contactPhone       String?
  plan               WorkspacePlan @default(free)
  createdAt          DateTime  @default(now())

  members            WorkspaceMember[]
  invitations        Invitation[]
  uploadedFiles      UploadedFile[]
  roles              Role[]
  sites              Site[]
  organizations      Organization[]
  people             Person[]
  deals              Deal[]
  projects           Project[]
  tasks              Task[]
  departments        Department[]
  announcements      Announcement[]
  documents          Document[]
  notifications      Notification[]
  activityLog        ActivityLogEntry[]
  searchIndex        SearchIndexEntry[]
  workflows          WorkflowDefinition[]
  integrations       Integration[]
  apiKeys            ApiKey[]
  aiConversations    AiConversation[]
  aiActionLogs       AiActionLog[]
  reports            ReportDefinition[]
  approvalRequests   ApprovalRequest[]
  vendors            Vendor[]
  expenses           Expense[]
  invoices           Invoice[]
  purchaseRequests   PurchaseRequest[]
  budgets            Budget[]
  emailMessages      EmailMessage[]
  chatChannels       ChatChannel[]
  callNotes          CallNote[]
  meetings           Meeting[]
  knowledgeArticles  KnowledgeArticle[]
  installations      WorkspaceInstallation[]
  branding           Branding?

  // platform-side relations (see PLATFORM section)
  subscription       Subscription?
  platformInvoices   PlatformInvoice[]
  supportTickets     SupportTicket[]
  featureOverrides   WorkspaceFeatureOverride[]
  aiUsageLogs        AiUsageLog[]
  storageSnapshots   StorageUsageSnapshot[]
  legalAcceptances   LegalAcceptance[]
  onboardingProgress WorkspaceOnboardingProgress[]
  emailDeliveryLogs  EmailDeliveryLog[]
  announcementTargets PlatformAnnouncementTarget[]
  convertedFromProspects SalesProspect[]

  @@map("workspaces")
}

// Matches the published tiers on the marketing site's pricing page
// (3stone-website/src/pricing/data/tiers.ts + published-pricing.ts) —
// the source of truth for plan names and prices, per the founder's
// stack-reconciliation charter ("read the existing pricing page, treat
// those prices as authoritative"). `free` is not one of the marketing
// site's sellable tiers; it's this app's own trial/starter state before
// a workspace picks a paid tier. `enterprise` has no fixed Stripe Price —
// the marketing site models it as `tierKey: null` ("price is a discovery
// call"), so Stripe checkout never runs for it; it's handled manually.
enum WorkspacePlan {
  free
  hub
  growth
  business_os
  enterprise
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String
  avatarUrl     String?
  passwordHash  String?
  // Set once, by verifyEmail — proof of the "Email Verified" onboarding
  // step. Deliberately not a boolean: the timestamp is itself the audit
  // record ("verified when"), not just a flag to check.
  emailVerifiedAt DateTime?
  // Updated on every real (non-demo) session creation — the founder
  // onboarding charter's "Last login" field. Never touched by demo
  // sessions (see login/actions.ts's demoLoginAction, which never reaches
  // recordLogin).
  lastLoginAt  DateTime?
  // Incremented on password change / reset completion — embedded in every
  // session cookie at creation time (lib/session.ts). A request whose
  // cookie carries a stale sessionVersion is treated as logged out, which
  // is what "session revocation after password changes" means for a
  // stateless-cookie session model: there's no server-side session table
  // to delete a row from, so invalidation works by making the number the
  // cookie carries stop matching the number in the database.
  sessionVersion Int      @default(0)
  // Null means "everything on" (the honest default — nobody has opted out
  // of anything yet), not an empty object meaning "everything off". Kept
  // as free-form Json rather than a fixed set of boolean columns so a new
  // notification category never needs its own migration.
  notificationPreferences Json?
  createdAt    DateTime  @default(now())

  workspaceMemberships WorkspaceMember[]
  staffMembership      StaffMembership?
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens  PasswordResetToken[]
  securityEvents       SecurityEvent[]
  invitationsSent      Invitation[] @relation("InvitedBy")
  uploadedFiles        UploadedFile[]

  @@map("users")
}

// Same shape as EmailVerificationToken (real, single-use, expiring) — the
// "password reset request" step's actual mechanism. Reset email delivery
// is stubbed the same way verification email is (see EmailVerificationToken's
// comment): the token itself is fully real, only the send is stubbed
// pending a verified sending domain.
model PasswordResetToken {
  token     String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("platform_password_reset_tokens")
}

// Real login history + account security events — one table for both,
// since "login history" is just this table filtered to type:"login".
// Distinct from PlatformAuditLogEntry (staff actions, cross-tenant) and
// from AuditLogEntry-per-module (business-record changes): this is a
// user's own account-security timeline, e.g. login, password_reset_requested,
// password_changed, sessions_revoked.
model SecurityEvent {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String
  ipAddress String?
  userAgent String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@map("platform_security_events")
}

// Real, single-use, expiring — the "Verify Email" step's actual
// mechanism. See docs/16-database-operations.md / the onboarding
// milestone report for why the email *send* is currently stubbed
// (logged, not delivered) while this token mechanism is fully real:
// sending requires a verified sending domain, which requires a DNS
// change, which is an explicit approval boundary, not something to do
// in passing here.
model EmailVerificationToken {
  token     String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("platform_email_verification_tokens")
}

model WorkspaceMember {
  id           String    @id @default(cuid())
  workspaceId  String
  workspace    Workspace @relation(fields: [workspaceId], references: [id])
  userId       String
  user         User      @relation(fields: [userId], references: [id])
  roleId       String
  role         Role      @relation(fields: [roleId], references: [id])
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])
  siteId       String?
  site         Site?     @relation(fields: [siteId], references: [id])
  status       MemberStatus @default(active)
  joinedAt     DateTime  @default(now())

  @@unique([workspaceId, userId])
  @@map("workspace_members")
}

enum MemberStatus {
  active
  invited
  suspended
}

// The real team-invitation mechanism: a token/expiry/status lifecycle
// distinct from WorkspaceMember. Accepting an invitation is what creates
// (or reactivates) the WorkspaceMember row — an Invitation is a standing
// offer, not membership itself, so it can be resent or revoked without
// ever having created a member.
enum InvitationStatus {
  pending
  accepted
  revoked
  expired
}

model Invitation {
  id              String   @id @default(cuid())
  workspaceId     String
  workspace       Workspace @relation(fields: [workspaceId], references: [id])
  email           String
  roleId          String
  role            Role     @relation(fields: [roleId], references: [id])
  token           String   @unique @default(cuid())
  status          InvitationStatus @default(pending)
  invitedByUserId String
  invitedBy       User     @relation("InvitedBy", fields: [invitedByUserId], references: [id])
  expiresAt       DateTime
  acceptedAt      DateTime?
  revokedAt       DateTime?
  createdAt       DateTime @default(now())

  @@index([workspaceId, status])
  @@map("workspace_invitations")
}

model IndustryProfile {
  key                String  @id
  label              String
  terminologyMap     Json
  moduleVisibility   Json
  customFieldSchemas Json
  pipelineStages     Json
  workspaces         Workspace[]

  @@map("industry_profiles")
}

// =============================================================================
// ROLES & PERMISSIONS — see docs/05-roles-and-permissions.md.
// Five workspace roles (Owner, Admin, Manager, Member, Client) — kept as-is
// per the founder's explicit decision not to merge Owner/Admin.
// =============================================================================

model Role {
  id           String    @id @default(cuid())
  workspaceId  String?
  workspace    Workspace? @relation(fields: [workspaceId], references: [id])
  name         String
  isSystemRole Boolean   @default(false)
  members      WorkspaceMember[]
  permissions  Permission[]
  invitations  Invitation[]

  @@map("roles")
}

model Permission {
  id       String @id @default(cuid())
  roleId   String
  role     Role   @relation(fields: [roleId], references: [id])
  module   String
  action   PermissionAction
  scope    PermissionScope

  @@map("permissions")
}

enum PermissionAction {
  view
  create
  edit
  delete
  approve
  export
  manage_settings
}

enum PermissionScope {
  all
  department
  own
  shared
}

// =============================================================================
// CRM
// =============================================================================

model Organization {
  id           String   @id @default(cuid())
  workspaceId  String
  workspace    Workspace @relation(fields: [workspaceId], references: [id])
  name         String
  domain       String?
  industry     String?
  ownerId      String?
  customFields Json?
  createdAt    DateTime @default(now())

  people       Person[]
  deals        Deal[]
  projects     Project[]
  documents    Document[]
  invoices     Invoice[]
  emailMessages EmailMessage[]
  callNotes    CallNote[]

  @@map("organizations")
}

enum PersonType {
  lead
  customer
  contact
  employee
  client
}

model Person {
  id             String    @id @default(cuid())
  workspaceId    String
  workspace      Workspace @relation(fields: [workspaceId], references: [id])
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  personType     PersonType
  firstName      String
  lastName       String
  email          String?
  phone          String?
  stageKey       String?
  ownerId        String?
  customFields   Json?
  createdAt      DateTime  @default(now())

  deals          Deal[]
  invoices       Invoice[]
  uploadedDocuments Document[] @relation("DocumentUploadedByPerson")
  callNotes      CallNote[]
  chatMessages   ChatMessage[] @relation("ChatMessageAuthorPerson")
  approvalRequests ApprovalRequest[] @relation("ApprovalRequestedByPerson")
  legalAcceptances LegalAcceptance[]

  @@map("people")
}

model Deal {
  id               String    @id @default(cuid())
  workspaceId      String
  workspace        Workspace @relation(fields: [workspaceId], references: [id])
  personId         String
  person           Person    @relation(fields: [personId], references: [id])
  organizationId   String?
  organization     Organization? @relation(fields: [organizationId], references: [id])
  title            String
  value            Decimal   @db.Decimal(12, 2)
  stageKey         String
  ownerId          String?
  expectedCloseDate DateTime?
  status           DealStatus @default(open)
  createdAt        DateTime  @default(now())

  @@map("deals")
}

enum DealStatus {
  open
  won
  lost
}

// =============================================================================
// PROJECTS & TASKS (relabeled per industry)
// =============================================================================

model Project {
  id             String    @id @default(cuid())
  workspaceId    String
  workspace      Workspace @relation(fields: [workspaceId], references: [id])
  siteId         String?
  site           Site?     @relation(fields: [siteId], references: [id])
  name           String
  description    String?
  statusKey      String
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  ownerId        String?
  startDate      DateTime?
  dueDate        DateTime?
  customFields   Json?
  createdAt      DateTime  @default(now())

  milestones     ProjectMilestone[]
  tasks          Task[]
  documents      Document[]
  budgets        Budget[]

  @@map("projects")
}

enum MilestoneStatus {
  pending
  in_progress
  approved
  rejected
}

model ProjectMilestone {
  id                String    @id @default(cuid())
  workspaceId       String
  projectId         String
  project           Project   @relation(fields: [projectId], references: [id])
  title             String
  dueDate           DateTime?
  status            MilestoneStatus @default(pending)
  approvalRequestId String?   @unique
  approvalRequest   ApprovalRequest? @relation(fields: [approvalRequestId], references: [id])
  createdAt         DateTime  @default(now())

  @@map("project_milestones")
}

enum TaskStatus {
  todo
  in_progress
  done
}

model Task {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  projectId   String?
  project     Project?  @relation(fields: [projectId], references: [id])
  title       String
  description String?
  assigneeId  String?
  status      TaskStatus @default(todo)
  dueDate     DateTime?
  createdAt   DateTime  @default(now())

  @@map("tasks")
}

// =============================================================================
// PEOPLE / EMPLOYEE PORTAL
// =============================================================================

model Department {
  id          String   @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  name        String
  leadUserId  String?

  members       WorkspaceMember[]
  announcements Announcement[]
  budgets       Budget[]
  chatChannels  ChatChannel[]

  @@map("departments")
}

model Announcement {
  id           String   @id @default(cuid())
  workspaceId  String
  workspace    Workspace @relation(fields: [workspaceId], references: [id])
  authorId     String?
  title        String
  body         String
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])
  publishedAt  DateTime @default(now())

  @@map("announcements")
}

enum DocumentVisibility {
  internal
  shared_with_client
}

model Document {
  id                 String   @id @default(cuid())
  workspaceId        String
  workspace          Workspace @relation(fields: [workspaceId], references: [id])
  name               String
  storageKey         String
  mimeType           String
  sizeBytes          Int
  uploadedById       String?
  uploadedByPersonId String?
  uploadedByPerson   Person?  @relation("DocumentUploadedByPerson", fields: [uploadedByPersonId], references: [id])
  projectId          String?
  project            Project? @relation(fields: [projectId], references: [id])
  organizationId     String?
  organization       Organization? @relation(fields: [organizationId], references: [id])
  visibility         DocumentVisibility @default(internal)
  createdAt          DateTime @default(now())

  @@map("documents")
}

// =============================================================================
// NOTIFICATIONS, ACTIVITY, SEARCH
// =============================================================================

model Notification {
  id          String   @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  userId      String
  type        String
  payload     Json?
  readAt      DateTime?
  createdAt   DateTime @default(now())

  @@map("notifications")
}

model ActivityLogEntry {
  id          String   @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  actorId     String?
  action      String
  entityType  String
  entityId    String
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([workspaceId, createdAt])
  @@map("activity_log_entries")
}

// SearchIndexEntry: the real column also needs a Postgres `tsvector` +
// GIN index, added by raw SQL in the initial migration (Prisma models a
// tsvector column as Unsupported — see the generated migration for the
// ALTER TABLE / CREATE INDEX statements).
model SearchIndexEntry {
  id           String   @id @default(cuid())
  workspaceId  String
  workspace    Workspace @relation(fields: [workspaceId], references: [id])
  entityType   String
  entityId     String
  title        String
  snippet      String?
  updatedAt    DateTime @updatedAt
  // Generated column, added by raw SQL in the initial migration — Prisma
  // has no native tsvector type, and Unsupported fields are excluded from
  // the generated client but keep `migrate diff` from thinking this column
  // shouldn't exist.
  searchVector Unsupported("tsvector")?

  @@unique([workspaceId, entityType, entityId])
  @@map("search_index_entries")
}

// =============================================================================
// AUTOMATION
// =============================================================================

model WorkflowDefinition {
  id          String   @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  name        String
  isActive    Boolean  @default(true)
  graph       Json
  createdById String?
  createdAt   DateTime @default(now())

  runs        WorkflowRun[]

  @@map("workflow_definitions")
}

enum WorkflowRunStatus {
  running
  success
  failed
}

model WorkflowRun {
  id                   String   @id @default(cuid())
  workflowDefinitionId String
  workflowDefinition   WorkflowDefinition @relation(fields: [workflowDefinitionId], references: [id])
  triggeredAt          DateTime @default(now())
  status               WorkflowRunStatus
  log                  Json?

  @@map("workflow_runs")
}

// =============================================================================
// INTEGRATIONS (customer's own connected tools — distinct from platform
// System Health, which tracks 3Stone AI's own integration health)
// =============================================================================

enum IntegrationStatus {
  not_connected
  connected
  error
}

model Integration {
  id          String   @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  provider    String
  status      IntegrationStatus @default(not_connected)
  connectedAt DateTime?
  config      Json?

  @@unique([workspaceId, provider])
  @@map("integrations")
}

model ApiKey {
  id          String   @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  label       String
  hashedKey   String
  createdById String?
  lastUsedAt  DateTime?
  revokedAt   DateTime?
  createdAt   DateTime @default(now())

  @@map("api_keys")
}

// =============================================================================
// AI (assistant + per-module capabilities) — see docs/01-architecture.md §5
// =============================================================================

enum AiMessageRole {
  user
  assistant
}

model AiConversation {
  id          String   @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  userId      String
  title       String?
  createdAt   DateTime @default(now())

  messages    AiMessage[]

  @@map("ai_conversations")
}

model AiMessage {
  id             String   @id @default(cuid())
  conversationId String
  conversation   AiConversation @relation(fields: [conversationId], references: [id])
  role           AiMessageRole
  content        String
  createdAt      DateTime @default(now())

  @@map("ai_messages")
}

model AiActionLog {
  id            String   @id @default(cuid())
  workspaceId   String
  workspace     Workspace @relation(fields: [workspaceId], references: [id])
  capabilityKey String
  entityType    String?
  entityId      String?
  input         Json?
  output        Json?
  invokedById   String?
  createdAt     DateTime @default(now())

  @@map("ai_action_logs")
}

// =============================================================================
// REPORTING
// =============================================================================

model ReportDefinition {
  id          String   @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  name        String
  type        String
  parameters  Json?
  config      Json
  generatedAt DateTime?
  createdById String?
  createdAt   DateTime @default(now())

  @@map("report_definitions")
}

// =============================================================================
// SITES (multi-location)
// =============================================================================

enum SiteType {
  office
  restaurant
  warehouse
  job_site
  clinic
  other
}

model Site {
  id           String   @id @default(cuid())
  workspaceId  String
  workspace    Workspace @relation(fields: [workspaceId], references: [id])
  name         String
  address      String?
  type         SiteType @default(other)
  customFields Json?
  createdAt    DateTime @default(now())

  members      WorkspaceMember[]
  projects     Project[]

  @@map("sites")
}

// =============================================================================
// APPROVALS — one generic mechanism, reused by ProjectMilestone + PurchaseRequest
// =============================================================================

enum ApprovalEntityType {
  project_milestone
  purchase_request
}

enum ApprovalStatus {
  pending
  approved
  rejected
}

model ApprovalRequest {
  id                  String   @id @default(cuid())
  workspaceId         String
  workspace           Workspace @relation(fields: [workspaceId], references: [id])
  entityType          ApprovalEntityType
  entityId            String
  requestedById       String?
  requestedByPersonId String?
  requestedByPerson   Person?  @relation("ApprovalRequestedByPerson", fields: [requestedByPersonId], references: [id])
  approverId          String?
  status              ApprovalStatus @default(pending)
  decidedAt           DateTime?
  notes               String?
  createdAt           DateTime @default(now())

  projectMilestone    ProjectMilestone?
  purchaseRequest     PurchaseRequest?

  @@map("approval_requests")
}

// =============================================================================
// FINANCE — decision support, not a ledger (docs/01-architecture.md §8)
// =============================================================================

model Vendor {
  id          String   @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  name        String
  contactInfo Json?
  createdAt   DateTime @default(now())

  expenses    Expense[]
  purchaseRequests PurchaseRequest[]

  @@map("vendors")
}

enum RecordSource {
  manual
  quickbooks_sync
}

model Expense {
  id          String   @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  vendorId    String?
  vendor      Vendor?  @relation(fields: [vendorId], references: [id])
  amount      Decimal  @db.Decimal(12, 2)
  category    String
  date        DateTime
  source      RecordSource @default(manual)
  createdAt   DateTime @default(now())

  @@map("expenses")
}

enum InvoiceStatus {
  draft
  sent
  paid
  overdue
  void
}

// The CUSTOMER's own accounts-receivable invoice (they bill their clients) —
// distinct from PlatformInvoice below (3Stone AI billing the workspace itself).
model Invoice {
  id                     String   @id @default(cuid())
  workspaceId            String
  workspace              Workspace @relation(fields: [workspaceId], references: [id])
  organizationId         String?
  organization           Organization? @relation(fields: [organizationId], references: [id])
  personId               String?
  person                 Person?  @relation(fields: [personId], references: [id])
  amount                 Decimal  @db.Decimal(12, 2)
  status                 InvoiceStatus @default(draft)
  dueDate                DateTime?
  source                 RecordSource @default(manual)
  stripePaymentIntentId  String?
  createdAt              DateTime @default(now())

  payments               Payment[]

  @@map("invoices")
}

model Payment {
  id        String   @id @default(cuid())
  invoiceId String
  invoice   Invoice  @relation(fields: [invoiceId], references: [id])
  amount    Decimal  @db.Decimal(12, 2)
  provider  String
  status    String
  paidAt    DateTime?

  @@map("payments")
}

model PurchaseRequest {
  id                String   @id @default(cuid())
  workspaceId       String
  workspace         Workspace @relation(fields: [workspaceId], references: [id])
  requestedById     String?
  vendorId          String?
  vendor            Vendor?  @relation(fields: [vendorId], references: [id])
  amount            Decimal  @db.Decimal(12, 2)
  justification     String?
  approvalRequestId String   @unique
  approvalRequest   ApprovalRequest @relation(fields: [approvalRequestId], references: [id])
  createdAt         DateTime @default(now())

  @@map("purchase_requests")
}

model Budget {
  id           String   @id @default(cuid())
  workspaceId  String
  workspace    Workspace @relation(fields: [workspaceId], references: [id])
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])
  projectId    String?
  project      Project? @relation(fields: [projectId], references: [id])
  period       String
  amount       Decimal  @db.Decimal(12, 2)
  createdAt    DateTime @default(now())

  @@map("budgets")
}

